{
  "manifest_kind": "vibeskills-distribution-manifest",
  "manifest_version": 1,
  "package_id": "vibeskills-cursor",
  "package_name": "VibeSkills for Cursor (Preview)",
  "status": "preview",
  "runtime_role": "host-adapter-preview",
  "summary": "Cursor exposes preview adapter entrypoints and truthful readiness boundaries, but this repository does not claim governed or host-native closure for it.",
  "truth_sources": [
    "docs/universalization/host-capability-matrix.md",
    "docs/universalization/platform-parity-contract.md",
    "docs/universalization/distribution-lanes.md",
    "adapters/cursor/host-profile.json",
    "adapters/cursor/platform-windows.json",
    "adapters/cursor/platform-linux.json",
    "adapters/cursor/platform-macos.json",
    "README.md"
  ],
  "host_adapter_ref": "adapters/cursor/host-profile.json",
  "platform_contracts": [
    "adapters/cursor/platform-windows.json",
    "adapters/cursor/platform-linux.json",
    "adapters/cursor/platform-macos.json"
  ],
  "entry_manifest": "dist/host-cursor/manifest.json",
  "install_entrypoints": {
    "repo_provided": [
      "install.ps1 --host cursor",
      "install.sh --host cursor",
      "check.ps1 --host cursor",
      "check.sh --host cursor"
    ],
    "host_managed": [
      "real host settings",
      "plugin enablement",
      "MCP registration",
      "provider credentials"
    ],
    "notes": [
      "This remains a preview-scaffold lane.",
      "Preview entrypoints do not imply host-native governed closure."
    ]
  },
  "degrade_states": {
    "missing_provider_credentials": "degraded-but-supported",
    "missing_host_plugins": "degraded-but-supported",
    "unverified_platform_lane": "not-yet-proven"
  },
  "anti_overclaim": [
    "Cursor support here is preview-only.",
    "Shared entrypoints do not imply takeover of real Cursor settings or host-native closure."
  ]
}
